# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — the app MUST connect as a non-superuser or RLS is bypassed.
# app_user is created by docker/postgres/init.sql on first init.
DB_NAME=pg_platform
DB_USER=app_user
DB_PASSWORD=app_password
DB_HOST=db
DB_PORT=5432
POSTGRES_ADMIN_PASSWORD=postgres

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# AWS S3 (document uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-south-1

# Razorpay — subscription billing ONLY, never resident payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email
EMAIL_HOST=smtp.mailgun.org
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
